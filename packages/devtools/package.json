{
  "name": "@byloth/micro-ecs-devtools",
  "version": "0.1.0",
  "description": "Developer tools for @byloth/micro-ecs — inspect entities, components, systems and resources in real time.",
  "keywords": [
    "ECS",
    "Entity Component System",
    "DevTools",
    "Debug",
    "Vue"
  ],
  "homepage": "https://github.com/Byloth/micro-ecs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byloth/micro-ecs.git",
    "directory": "packages/devtools"
  },
  "author": {
    "name": "Matteo Bilotta",
    "email": "me@byloth.dev",
    "url": "https://www.byloth.dev/"
  },
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/client/micro-ecs-devtools.cjs",
  "module": "dist/client/micro-ecs-devtools.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./src/index.ts",
        "default": "./dist/client/micro-ecs-devtools.js"
      },
      "require": {
        "types": "./src/index.ts",
        "default": "./dist/client/micro-ecs-devtools.cjs"
      }
    },
    "./plugin": {
      "import": {
        "types": "./src/server/index.ts",
        "default": "./dist/plugin/plugin.js"
      }
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --mode client && vite build --mode plugin",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@byloth/micro-ecs": "workspace:^"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-vue": "^5.2.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.10"
  }
}
